<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="6dp">

    <TextView
        android:id="@+id/header_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Избранное"
        android:textColor="#CCFFFFFF"
        android:textSize="1sp"
        android:textStyle="bold"
        android:layout_marginBottom="0dp"/>

    <TextView android:id="@+id/row1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● BTC   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● ETH   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● SOL   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● GMT   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● XAU   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● Brent   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="3dp"/>

    <TextView android:id="@+id/row7"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="● USD/RUB   —" android:textColor="#FFFFFF"
        android:textSize="14sp" android:textStyle="bold"/>
    <TextView android:id="@+id/change7"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp"/>

</LinearLayout>
