<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:padding="6dp">

    <TextView android:id="@+id/header_updated"
        android:layout_width="1dp" android:layout_height="1dp"
        android:text="" android:layout_alignParentTop="true"/>

    <!-- ROW 1 -->
    <TextView android:id="@+id/row1"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/header_updated"
        android:text="BTC" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price1"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/header_updated" android:layout_toRightOf="@id/row1"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change1"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/header_updated" android:layout_toRightOf="@id/price1"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 2 -->
    <TextView android:id="@+id/row2"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row1"
        android:text="ETH" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price2"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row1" android:layout_toRightOf="@id/row2"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change2"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row1" android:layout_toRightOf="@id/price2"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 3 -->
    <TextView android:id="@+id/row3"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row2"
        android:text="SOL" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price3"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row2" android:layout_toRightOf="@id/row3"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change3"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row2" android:layout_toRightOf="@id/price3"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 4 -->
    <TextView android:id="@+id/row4"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row3"
        android:text="DOGE" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price4"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row3" android:layout_toRightOf="@id/row4"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change4"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row3" android:layout_toRightOf="@id/price4"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 5 -->
    <TextView android:id="@+id/row5"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row4"
        android:text="LTC" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price5"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row4" android:layout_toRightOf="@id/row5"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change5"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row4" android:layout_toRightOf="@id/price5"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 6 -->
    <TextView android:id="@+id/row6"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row5"
        android:text="GMT" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price6"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row5" android:layout_toRightOf="@id/row6"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change6"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row5" android:layout_toRightOf="@id/price6"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 7 -->
    <TextView android:id="@+id/row7"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row6"
        android:text="XAU" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price7"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row6" android:layout_toRightOf="@id/row7"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change7"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row6" android:layout_toRightOf="@id/price7"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 8 -->
    <TextView android:id="@+id/row8"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row7"
        android:text="Brent" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price8"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row7" android:layout_toRightOf="@id/row8"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change8"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row7" android:layout_toRightOf="@id/price8"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

    <!-- ROW 9 -->
    <TextView android:id="@+id/row9"
        android:layout_width="110dp" android:layout_height="32dp"
        android:layout_below="@id/row8"
        android:text="USD/RUB" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/price9"
        android:layout_width="130dp" android:layout_height="32dp"
        android:layout_below="@id/row8" android:layout_toRightOf="@id/row9"
        android:text="—" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:gravity="center_vertical"/>
    <TextView android:id="@+id/change9"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:layout_below="@id/row8" android:layout_toRightOf="@id/price9"
        android:text="" android:textSize="12sp" android:gravity="center_vertical"/>

</RelativeLayout>
