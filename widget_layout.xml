<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="6dp">

    <!-- header скрыт но нужен для RemoteViews id -->
    <TextView android:id="@+id/header_updated"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:text="" android:textSize="1sp"/>

    <!-- Макрос строки: буллет(цвет) | тикер 16sp bold | отступ | цена 15sp bold | % 12sp -->
    <TextView android:id="@+id/row1"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● BTC" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row2"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● ETH" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row3"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● SOL" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row4"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● DOGE" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row5"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● LTC" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row6"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● GMT" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row7"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● XAU" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change7"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row8"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● Brent" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change8"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="2dp" android:paddingLeft="16dp"/>

    <TextView android:id="@+id/row9"
        android:layout_width="match_parent" android:layout_height="34dp"
        android:text="● USD/RUB" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:gravity="center_vertical"/>
    <TextView android:id="@+id/change9"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:paddingLeft="16dp"/>

</LinearLayout>
