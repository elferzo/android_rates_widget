<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <TextView
        android:id="@+id/header_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Обновлено только что"
        android:textColor="#88FFFFFF"
        android:textSize="10sp"
        android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row1"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="BTC" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row2"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="ETH" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row3"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="SOL" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row4"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="XAU" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row5"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="Brent" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/row6"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:text="USD/RUB" android:textColor="#B0B0B0" android:textSize="13sp" android:textStyle="bold"
        android:gravity="center_vertical"/>

    <TextView android:id="@+id/price6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/change6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="11sp"/>

</LinearLayout>
